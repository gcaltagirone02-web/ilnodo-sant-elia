---
// SunsetExperience.astro
import { Image } from "astro:assets";
import sunsetDesktop from "../assets/images/golden-hour-dektop-il-nodo.png";
import sunsetMobile from "../assets/images/golden-hour-mobile-il-nodo.png";
import { useTranslations } from "../i18n/ui";

interface Props {
  id?: string;
}

const lang = (Astro.currentLocale as "it" | "en" | "fr") || "it";
const t = useTranslations(lang);

const { id = t('sunset.id') } = Astro.props;

// WhatsApp pre-compiled messages
const whatsappBase = "https://api.whatsapp.com/send?phone=393661770312&text=";
const sunsetMessages: Record<string, string> = {
  it: "Ciao! Vorrei prenotare un tavolo per il tramonto al Nodo.\n- Nome: \n- Data: \n- Persone: \n- Orario: \nGrazie!",
  en: "Hi! I'd like to book a table for sunset at Il Nodo.\n- Name: \n- Date: \n- People: \n- Time: \nThank you!",
  fr: "Bonjour ! Je souhaiterais réserver une table pour le coucher du soleil au Nodo.\n- Prénom : \n- Date : \n- Personnes : \n- Heure : \nMerci !",
};
const sunsetWhatsappLink = `${whatsappBase}${encodeURIComponent(sunsetMessages[lang])}`;
---

<section id={id} class="sunset-experience relative min-h-[80vh] flex items-center overflow-hidden">
  <!-- Background Image with Parallax Effect -->
  <div class="absolute inset-0 z-0">
    <!-- Desktop Background -->
    <Image 
      src={sunsetDesktop} 
      alt={lang === 'en' ? 'Spectacular sunset in Sant\'Elia' : 'Tramonto spettacolare a Sant\'Elia'} 
      class="hidden md:block w-full h-full object-cover scale-110 motion-safe:animate-slow-zoom"
    />
    <!-- Mobile Background -->
    <Image 
      src={sunsetMobile} 
      alt={lang === 'en' ? 'Spectacular sunset in Sant\'Elia' : 'Tramonto spettacolare a Sant\'Elia'} 
      class="block md:hidden w-full h-full object-cover scale-110 motion-safe:animate-slow-zoom"
    />
    <!-- Premium Overlay Mix -->
    <div class="absolute inset-0 bg-gradient-to-t from-stone-950 via-stone-950/40 to-transparent"></div>
    <div class="absolute inset-0 bg-stone-950/20 backdrop-brightness-75"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-3xl">
      <div class="space-y-2 mb-8 reveal">
        <span class="text-amber-500 font-semibold uppercase tracking-[0.3em] text-xs">{t("sunset.label")}</span>
        <h2 class="text-5xl md:text-7xl text-white font-serif leading-none tracking-tight">
          {t("sunset.title")} <br />
          <span class="italic text-amber-400">{t("sunset.accent")}</span>
        </h2>
      </div>

      <div class="space-y-8 reveal delay-100">
        <p class="text-stone-200 text-lg md:text-xl font-light leading-relaxed max-w-xl">
          {t("sunset.desc")}
        </p>

        <div class="flex flex-wrap gap-6 pt-4">
          <a 
            href={sunsetWhatsappLink} 
            class="px-8 py-4 bg-amber-500 hover:bg-amber-400 text-stone-950 font-bold rounded-full transition-all duration-300 hover:scale-105 hover:shadow-[0_0_30px_rgba(245,158,11,0.4)] flex items-center gap-2"
          >
            <span>{t("sunset.cta")}</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          
          <div class="flex items-center gap-4 py-4 px-6 rounded-full bg-white/5 border border-white/10 backdrop-blur-md">
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-amber-500"></span>
            </span>
            <span class="text-white text-sm font-medium">{t("sunset.badge")}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative blur -->
  <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-stone-950 to-transparent z-10"></div>
</section>

<style>
  @keyframes slow-zoom {
    0% { transform: scale(1.1); }
    50% { transform: scale(1.15); }
    100% { transform: scale(1.1); }
  }

  .animate-slow-zoom {
    animation: slow-zoom 20s ease-in-out infinite;
  }

  /* Reveal animations */
  @supports (animation-timeline: view()) {
    .reveal {
      animation: reveal-fade-up linear both;
      animation-timeline: view();
      animation-range: entry 10% cover 30%;
    }

    @keyframes reveal-fade-up {
      from {
        opacity: 0;
        transform: translateY(40px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }

  .delay-100 {
    animation-delay: 100ms;
  }
</style>
