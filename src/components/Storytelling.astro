---
import { Image } from "astro:assets";
import storytellingImg from "../assets/images/storytelling-golden-hour.png";
import { useTranslations } from "../i18n/ui";

interface Props {
  id?: string;
}

const lang = (Astro.currentLocale as "it" | "en" | "fr") || "it";
const t = useTranslations(lang);

const { id = t('story.id') } = Astro.props;
---

<section id={id} class="storytelling">
  <div class="container">
    <div class="storytelling__grid">
      <!-- Visual Column -->
      <div class="storytelling__visual reveal">
        <div class="storytelling__image-wrapper">
          <Image
            src={storytellingImg}
            alt={t('story.alt')}
            class="storytelling__image"
            format="avif"
            width={800}
            height={1000}
            loading="lazy"
          />
          <div class="storytelling__image-overlay"></div>
        </div>
      </div>

      <!-- Content Column -->
      <div class="storytelling__content reveal">
        <div class="storytelling__inner">
          <span class="storytelling__label">{t("story.label")}</span>
          <h2 class="storytelling__title">
            {t("story.title").split(". ")[0]}. <br />
            {t("story.title").split(". ")[1]} <br />
            <span class="italic text-accent">{t("story.accent")}</span>
          </h2>

          <div class="storytelling__text">
            <p>{t("story.p1")}</p>
            <p>{t("story.p2")}</p>
            <p class="storytelling__quote">{t("story.quote")}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .storytelling {
    background-color: var(--color-bg-primary);
    padding: clamp(4rem, 10vw, 8rem) 0;
    overflow: hidden;
  }

  .container {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .storytelling__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .storytelling__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Visual Column */
  .storytelling__visual {
    position: relative;
    z-index: 1;
  }

  .storytelling__image-wrapper {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--color-shadow-light);
    aspect-ratio: 4/5;
  }

  .storytelling__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-smooth) var(--ease-smooth);
  }

  .storytelling__visual:hover .storytelling__image {
    transform: scale(1.05);
  }

  .storytelling__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 60%,
      rgba(28, 25, 23, 0.3)
    );
    pointer-events: none;
  }

  /* Content Column */
  .storytelling__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .storytelling__label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .storytelling__title {
    font-size: var(--text-heading);
    line-height: 1.1;
    margin-bottom: 2rem;
    color: var(--color-text-primary);
  }

  .text-accent {
    color: var(--color-accent);
  }

  .storytelling__text {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .storytelling__text p {
    margin-bottom: 1.5rem;
  }

  .storytelling__quote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.5rem;
    color: var(--color-text-primary);
    border-left: 2px solid var(--color-accent);
    padding-left: 1.5rem;
    margin-top: 2rem;
  }

  /* Animations */
  @supports (animation-timeline: view()) {
    .reveal {
      animation: reveal-fade-up linear both;
      animation-timeline: view();
      animation-range: entry 10% cover 30%;
    }

    @keyframes reveal-fade-up {
      from {
        opacity: 0;
        transform: translateY(40px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
