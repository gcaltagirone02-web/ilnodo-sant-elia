---
/**
 * Navbar.astro
 * Floating pill navbar with advanced glassmorphism.
 * - Initially transparent, full-width
 * - On scroll → compact floating pill with glassmorphism + glow
 * - CSS hover pills with micro-animations
 * - Animated hamburger (X morphing)
 * - Mobile menu with stagger fade-up + backdrop blur
 */
import { Image } from "astro:assets";
import logoImg from "../assets/images/Logo.png";
import { useTranslations, languages } from "../i18n/ui";
import LanguagePicker from "./LanguagePicker.astro";

interface Props {
  currentPath?: string;
}

const lang = (Astro.currentLocale as "it" | "en") || "it";
const t = useTranslations(lang);
const { currentPath = Astro.url.pathname } = Astro.props;

const base = lang === "en" ? "/en" : "";

const navLinks = [
  { href: `${base}/#storia`, label: t("nav.storia") },
  { href: `${base}/menu`, label: t("nav.menu") },
  { href: `${base}/#sunset-experience`, label: t("nav.experience") },
  { href: `${base}/#galleria`, label: t("nav.gallery") },
  { href: lang === "en" ? "/en/#location" : "/#dove-siamo", label: t("nav.location") },
];

// Contextual WhatsApp messages
const whatsappBase = "https://api.whatsapp.com/send?phone=393661770312&text=";
const messages = {
  it: {
    home: "Ciao!%20Vorrei%20prenotare%20un%20tavolo%20per%20l'aperitivo%20a%20Sant'Elia.%20Saremo%20in%20%5Binserisci%20n.%20persone%5D%20alle%20ore%20%5Binserisci%20orario%5D.%20Grazie!",
    menu: "Ciao!%20Ho%20visto%20il%20vostro%20menu%20online%20e%20vorrei%20prenotare%20un%20tavolo.%20Saremo%20in%20%5Binserisci%20n.%20persone%5D%20alle%20ore%20%5Binserisci%20orario%5D.%20Grazie!",
  },
  en: {
    home: "Hi!%20I'd%20like%20to%20book%20a%20table%20for%20an%20aperitif%20in%20Sant'Elia.%20We%20will%20be%20%5Binsert%20n.%20people%5D%20at%20%5Binsert%20time%5D.%20Thank%20you!",
    menu: "Hi!%20I%20saw%20your%20online%20menu%20and%20I'd%20like%20to%20book%20a%20table.%20We%20will%20be%20%5Binsert%20n.%20people%5D%20at%20%5Binsert%20time%5D.%20Thank%20you!",
  },
};

const currentMessage =
  currentPath.includes("/menu") ? messages[lang].menu : messages[lang].home;
const whatsappLink = `${whatsappBase}${currentMessage}`;

// Helper to switch language keeping the same path
const getSwitchPath = (targetLang: string) => {
  const segments = currentPath.split("/").filter(Boolean);
  if (targetLang === "en") {
    if (segments[0] !== "en") return `/en${currentPath}`;
    return currentPath;
  } else {
    if (segments[0] === "en") {
      const newPath = "/" + segments.slice(1).join("/");
      return newPath === "" ? "/" : newPath;
    }
    return currentPath;
  }
};
---

<!-- Scroll sentinel -->
<div id="nav-sentinel" class="nav-sentinel" aria-hidden="true"></div>

<header id="site-header" class="site-header" role="banner">
  <nav class="site-nav" aria-label={t("nav.home")}>
    <!-- Logo -->
    <a
      href={lang === "en" ? "/en" : "/"}
      class="site-nav__logo"
      aria-label={`${t("nav.home")} — Il Nodo 2.0`}
    >
      <Image
        src={logoImg}
        alt="Il Nodo Logo"
        class="site-nav__logo-img"
        format="avif"
        loading="eager"
      />
    </a>

    <!-- Desktop nav links -->
    <ul class="site-nav__links" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "site-nav__link",
                { "site-nav__link--active": currentPath === link.href },
              ]}
              aria-current={currentPath === link.href ? "page" : undefined}
            >
              <span class="site-nav__link-text">{link.label}</span>
            </a>
          </li>
        ))
      }
    </ul>

    <div class="site-nav__actions">
      <!-- Premium Language Picker -->
      <LanguagePicker />

      <!-- CTA Button -->
      <a
        href={whatsappLink}
        class="site-nav__cta"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t("nav.book")}
      >
        <span class="site-nav__cta-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
            ></path>
            <path
              d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.117 1.534 5.847L0 24l6.335-1.518C8.02 23.447 9.972 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.893 0-3.66-.523-5.168-1.43l-.368-.217-3.762.902.934-3.664-.24-.38C2.517 15.614 2 13.865 2 12 2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"
            ></path>
          </svg>
        </span>
        <span>{t("nav.book")}</span>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      type="button"
      class="site-nav__hamburger"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Apri menu di navigazione"
    >
      <span class="site-nav__hamburger-icon" aria-hidden="true">
        <span class="site-nav__hamburger-bar"></span>
        <span class="site-nav__hamburger-bar"></span>
        <span class="site-nav__hamburger-bar"></span>
      </span>
    </button>
  </nav>
</header>

<!-- Mobile menu (hidden by default) -->
<div
  id="mobile-menu"
  class="mobile-menu"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Menu mobile"
>
  <!-- Close button inside menu -->
  <button
    type="button"
    class="mobile-menu__close"
    id="mobile-menu-close"
    aria-label="Chiudi menu"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      aria-hidden="true"
    >
      <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
    </svg>
  </button>

  <ul class="mobile-menu__links" role="list">
    {
      navLinks.map((link, i) => (
        <li style={`--stagger: ${i}`}>
          <a href={link.href} class="mobile-menu__link">
            <span class="mobile-menu__num">0{i + 1}</span>
            <span class="mobile-menu__text">{link.label}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
              class="mobile-menu__arrow"
            >
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </li>
      ))
    }
    <li style="--stagger: 4">
      <a
        href={whatsappLink}
        class="mobile-menu__link mobile-menu__link--cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
          ></path>
          <path
            d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.117 1.534 5.847L0 24l6.335-1.518C8.02 23.447 9.972 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.893 0-3.66-.523-5.168-1.43l-.368-.217-3.762.902.934-3.664-.24-.38C2.517 15.614 2 13.865 2 12 2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"
          ></path>
        </svg>
        <span class="mobile-menu__text">{lang === 'en' ? 'Book Now' : 'Prenota ora'}</span>
      </a>
    </li>
    <li style="--stagger: 5" class="mobile-menu__lang">
      <LanguagePicker />
    </li>
  </ul>
</div>

<!-- Minimal JS: scroll class toggle + mobile menu toggle -->
<script>
  const sentinel = document.getElementById("nav-sentinel");
  const header = document.getElementById("site-header");

  if (sentinel && header) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        header.classList.toggle("scrolled", !entry.isIntersecting);
      },
      { threshold: 0, rootMargin: "0px" },
    );
    observer.observe(sentinel);
  }

  const toggle = document.getElementById("nav-toggle");
  const closeBtn = document.getElementById("mobile-menu-close");
  const mobileMenu = document.getElementById("mobile-menu");

  function openMenu() {
    if (!toggle || !mobileMenu) return;
    toggle.setAttribute("aria-expanded", "true");
    mobileMenu.setAttribute("aria-hidden", "false");
    mobileMenu.classList.add("mobile-menu--open");
    toggle.classList.add("site-nav__hamburger--open");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    if (!toggle || !mobileMenu) return;
    toggle.setAttribute("aria-expanded", "false");
    mobileMenu.setAttribute("aria-hidden", "true");
    mobileMenu.classList.remove("mobile-menu--open");
    toggle.classList.remove("site-nav__hamburger--open");
    document.body.style.overflow = "";
  }

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    isOpen ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener("click", closeMenu);

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Close on ESC
  document.addEventListener("keydown", (e) => {
    if (
      e.key === "Escape" &&
      mobileMenu?.classList.contains("mobile-menu--open")
    ) {
      closeMenu();
    }
  });
</script>

<style>
  .nav-sentinel {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 80px;
    pointer-events: none;
  }

  /* ---- Header ---- */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: transparent;
    transition: padding var(--duration-smooth) var(--ease-smooth);
    padding: 1.25rem 0;
  }

  /* ---- Nav inner wrapper ---- */
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem clamp(1rem, 3vw, 2rem);
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    border-radius: 0;
    background: transparent;
    border: 1px solid transparent;
    transition:
      background var(--duration-smooth) var(--ease-smooth),
      border-color var(--duration-smooth) var(--ease-smooth),
      backdrop-filter var(--duration-smooth) var(--ease-smooth),
      border-radius var(--duration-smooth) var(--ease-smooth),
      box-shadow var(--duration-smooth) var(--ease-smooth),
      max-width var(--duration-smooth) var(--ease-smooth),
      padding var(--duration-smooth) var(--ease-smooth);
  }

  /* Floating pill on scroll */
  .site-header.scrolled {
    padding: 0.6rem 0;
  }

  .site-header.scrolled .site-nav {
    background: color-mix(in srgb, var(--color-bg-primary) 70%, transparent);
    backdrop-filter: blur(24px) saturate(2) brightness(1.1);
    -webkit-backdrop-filter: blur(24px) saturate(2) brightness(1.1);
    border-color: color-mix(in srgb, var(--color-white) 15%, transparent);
    border-radius: 9999px;
    box-shadow:
      0 10px 40px rgba(0 0 0 / 0.4),
      0 1px 0 rgba(255 255 255 / 0.1) inset,
      0 0 0 1px rgba(255 255 255 / 0.05) inset;
    max-width: 900px;
    padding: 0.6rem clamp(1rem, 3vw, 1.5rem);
    /* Subtle outer glow */
    outline: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    outline-offset: -1px;
  }

  /* ---- Logo ---- */
  .site-nav__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .site-nav__logo-img {
    height: 64px;
    width: auto;
    object-fit: contain;
    transition:
      opacity var(--duration-fast) var(--ease-smooth),
      transform var(--duration-fast) var(--ease-smooth),
      filter var(--duration-fast) var(--ease-smooth);
    /* Logo is white at the top for hero contrast */
    filter: brightness(0) invert(1);
  }

  .site-header.scrolled .site-nav__logo-img {
    height: 42px;
    /* Logo returns to original color when scrolled */
    filter: none;
  }

  .site-nav__logo:hover .site-nav__logo-img {
    opacity: 0.75;
    transform: scale(0.96);
    filter: brightness(1.1);
  }

  /* ---- Desktop links ---- */
  .site-nav__links {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-nav__link {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    padding: 0.45rem 1rem;
    border-radius: 9999px;
    position: relative;
    transition:
      color var(--duration-fast) var(--ease-smooth),
      background var(--duration-fast) var(--ease-smooth);
    /* Subtle inner glow on hover */
    isolation: isolate;
  }

  .site-nav__link::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-accent) 0%, transparent);
    transition: background var(--duration-fast) var(--ease-smooth);
    z-index: -1;
  }

  .site-nav__link:hover,
  .site-nav__link--active {
    color: var(--color-white);
  }

  /* Scrolled link colors */
  .site-header.scrolled .site-nav__link {
    color: var(--color-brand-blue);
    opacity: 0.85;
    font-size: 0.875rem;
  }

  .site-header.scrolled .site-nav__link:hover,
  .site-header.scrolled .site-nav__link--active {
    color: var(--color-brand-blue);
    opacity: 1;
  }

  .site-nav__link:hover::before {
    background: color-mix(in srgb, var(--color-white) 12%, transparent);
    transform: scale(1.05);
  }

  .site-nav__link--active::before {
    background: color-mix(in srgb, var(--color-accent) 20%, transparent);
    box-shadow: 0 0 15px
      color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  .site-nav__link--active {
    color: var(--color-accent-light);
    font-weight: 600;
  }

  .site-nav__actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .site-nav__link-text {
    position: relative;
    display: inline-block;
  }

  /* ---- CTA Button ---- */
  .site-nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-bg-primary);
    background: var(--color-cta);
    padding: 0.5rem 1.15rem;
    border-radius: 9999px;
    text-decoration: none;
    min-height: 40px;
    transition:
      background var(--duration-fast) var(--ease-smooth),
      transform var(--duration-fast) var(--ease-smooth),
      box-shadow var(--duration-fast) var(--ease-smooth),
      color var(--duration-fast) var(--ease-smooth);
    flex-shrink: 0;
    overflow: hidden;
    position: relative;
  }

  .site-header.scrolled .site-nav__cta {
    font-size: 0.875rem;
    padding: 0.55rem 1.25rem;
    min-height: 44px;
  }

  .site-nav__cta::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(255 255 255 / 0);
    transition: background var(--duration-fast) var(--ease-smooth);
    border-radius: inherit;
  }

  .site-nav__cta:hover::after {
    background: rgba(255 255 255 / 0.12);
  }

  .site-nav__cta:hover {
    background: color-mix(in srgb, var(--color-cta) 90%, white);
    transform: translateY(-1px) scale(1.02);
    box-shadow:
      0 6px 24px color-mix(in srgb, var(--color-cta) 45%, transparent),
      0 2px 8px color-mix(in srgb, var(--color-cta) 20%, transparent);
  }

  .site-nav__cta:active {
    transform: translateY(0) scale(0.99);
  }

  .site-nav__cta-icon {
    display: inline-flex;
    align-items: center;
    transition: transform var(--duration-fast) var(--ease-smooth);
  }

  .site-nav__cta:hover .site-nav__cta-icon {
    transform: rotate(-10deg) scale(1.15);
  }

  /* ---- Hamburger ---- */
  .site-nav__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 44px;
    height: 44px;
    background: color-mix(in srgb, var(--color-white) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-white) 10%, transparent);
    border-radius: 9999px;
    cursor: pointer;
    padding: 0;
    transition:
      background var(--duration-fast) var(--ease-smooth),
      border-color var(--duration-fast) var(--ease-smooth),
      transform var(--duration-fast) var(--ease-smooth);
  }

  .site-nav__hamburger:hover {
    background: color-mix(in srgb, var(--color-white) 14%, transparent);
    border-color: color-mix(in srgb, var(--color-white) 25%, transparent);
    transform: scale(1.05);
  }

  .site-nav__hamburger:active {
    transform: scale(0.95);
  }

  .site-nav__hamburger-icon {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 22px;
  }

  .site-nav__hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-white);
    transition:
      transform 400ms cubic-bezier(0.23, 1, 0.32, 1),
      opacity 250ms var(--ease-smooth),
      width 350ms var(--ease-smooth);
    transform-origin: center;
  }

  /* Hamburger → X morphing */
  .site-nav__hamburger--open .site-nav__hamburger-bar {
    background-color: var(--color-brand-blue);
  }

  .site-nav__hamburger--open .site-nav__hamburger-bar:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
    width: 22px;
  }

  .site-nav__hamburger--open .site-nav__hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
    width: 0;
  }

  .site-nav__hamburger--open .site-nav__hamburger-bar:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
    width: 22px;
  }

  /* Scrolled state colors */
  .site-header.scrolled .site-nav__hamburger-bar {
    background-color: var(--color-brand-blue);
  }

  .site-header.scrolled .site-nav__hamburger {
    background: color-mix(in srgb, var(--color-brand-blue) 5%, transparent);
    border-color: color-mix(in srgb, var(--color-brand-blue) 15%, transparent);
  }

  /* ---- Mobile menu ---- */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--color-bg-primary);
    padding: 7rem clamp(1.5rem, 6vw, 3rem) 4rem;
    z-index: 100;
    flex-direction: column;
    justify-content: flex-start;
    align-items: stretch;
    opacity: 0;
    transform: translateY(-8px);
    transition:
      opacity var(--duration-smooth) var(--ease-smooth),
      transform var(--duration-smooth) var(--ease-smooth);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mobile-menu--open {
    display: flex;
    animation: menu-appear 380ms cubic-bezier(0.23, 1, 0.32, 1) forwards;
  }

  @keyframes menu-appear {
    from {
      opacity: 0;
      transform: translateY(-12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Close button inside mobile menu */
  .mobile-menu__close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 54px;
    height: 54px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-white);
    border: 2px solid var(--color-accent);
    border-radius: 9999px;
    color: var(--color-brand-blue);
    cursor: pointer;
    transition:
      background var(--duration-fast) var(--ease-smooth),
      color var(--duration-fast) var(--ease-smooth),
      transform var(--duration-fast) var(--ease-smooth);
  }

