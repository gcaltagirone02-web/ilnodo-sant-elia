---
import { Image } from "astro:assets";
import cocktailImg from "../assets/images/cocktail-2.png";
import foodImg from "../assets/images/bruschettone-macro.png";
import traditionImg from "../assets/images/cocktail-basilico.png";
import { useTranslations } from "../i18n/ui";

interface Props {
  id?: string;
}

const lang = (Astro.currentLocale as "it" | "en" | "fr") || "it";
const t = useTranslations(lang);

const { id = t('highlights.id') } = Astro.props;

const highlights = [
  {
    title: t("highlights.mixology.title"),
    description: t("highlights.mixology.desc"),
    image: cocktailImg,
    label: t("highlights.mixology.label"),
  },
  {
    title: t("highlights.flavor.title"),
    description: t("highlights.flavor.desc"),
    image: foodImg,
    label: t("highlights.flavor.label"),
  },
  {
    title: t("highlights.tradition.title"),
    description: t("highlights.tradition.desc"),
    image: traditionImg,
    label: t("highlights.tradition.label"),
  },
];
---

<section id={id} class="product-highlights">
  <div class="container">
    <div class="product-highlights__header reveal">
      <span class="product-highlights__label">{t("highlights.label")}</span>
      <h2 class="product-highlights__title">
        {t("highlights.title")} <br />
        <span class="italic text-accent">{t("highlights.accent")}</span>
      </h2>
    </div>

    <div class="product-highlights__grid">
      {
        highlights.map((item, index) => (
          <div class={`product-highlights__card reveal delay-${index}`}>
            <div class="product-highlights__image-wrapper">
              <Image
                src={item.image}
                alt={item.title}
                class="product-highlights__image"
                width={600}
                height={800}
                format="avif"
                loading="lazy"
              />
              <div class="product-highlights__overlay" />
            </div>
            <div class="product-highlights__content">
              <span class="product-highlights__card-label">{item.label}</span>
              <h3 class="product-highlights__card-title">{item.title}</h3>
              <p class="product-highlights__card-text">{item.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .product-highlights {
    background-color: var(--color-bg-primary);
    padding: clamp(4rem, 10vw, 8rem) 0;
  }

  .container {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .product-highlights__header {
    margin-bottom: 4rem;
    text-align: center;
  }

  .product-highlights__label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .product-highlights__title {
    font-size: var(--text-heading);
    line-height: 1.1;
    color: var(--color-text-primary);
  }

  .text-accent {
    color: var(--color-accent);
  }

  .product-highlights__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .product-highlights__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .product-highlights__card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 3/4;
    transition: transform var(--duration-smooth) var(--ease-smooth);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
    box-shadow: var(--color-shadow-light);
  }

  .product-highlights__card:hover {
    transform: translateY(-8px);
  }

  .product-highlights__image-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .product-highlights__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-smooth) var(--ease-smooth);
  }

  .product-highlights__card:hover .product-highlights__image {
    transform: scale(1.1);
  }

  .product-highlights__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(15, 28, 70, 0.8) 100%
    );
  }

  .product-highlights__content {
    position: relative;
    z-index: 1;
    color: white;
  }

  .product-highlights__card-label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    display: block;
  }

  .product-highlights__card-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-style: italic;
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .product-highlights__card-text {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.9);
  }

  /* Animations */
  @supports (animation-timeline: view()) {
    .reveal {
      animation: reveal-fade-up linear both;
      animation-timeline: view();
      animation-range: entry 5% cover 25%;
    }

    .delay-1 {
      animation-delay: 100ms;
    }
    .delay-2 {
      animation-delay: 200ms;
    }

    @keyframes reveal-fade-up {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
