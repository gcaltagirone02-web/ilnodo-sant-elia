---
import { useTranslations } from "../i18n/ui";

const lang = (Astro.currentLocale as "it" | "en" | "fr") || "it";
const t = useTranslations(lang);

const reviews = [
  {
    name: "Santina C.",
    date: t('reviews.item1.date'),
    stars: 5,
    text: t('reviews.item1.text'),
    source: "Google Reviews",
  },
  {
    name: "Francesca Brun",
    date: t('reviews.item2.date'),
    stars: 5,
    text: t('reviews.item2.text'),
    source: "Google Reviews",
  },
  {
    name: "Giuseppe Ceruso",
    date: t('reviews.item3.date'),
    stars: 5,
    text: t('reviews.item3.text'),
    source: "Facebook",
  },
  {
    name: "Sofia Gagliardi",
    date: t('reviews.item4.date'),
    stars: 5,
    text: t('reviews.item4.text'),
    source: "TripAdvisor",
  },
];
---

<section id={t('reviews.id')} class="py-24 bg-stone-100 overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16 space-y-4" data-aos="fade-up">
      <span class="block text-amber-800 font-medium tracking-widest uppercase text-sm">
        {t("reviews.label")}
      </span>
      <h2 class="text-4xl md:text-5xl font-serif text-stone-900">
        {t("reviews.title")}
      </h2>
      <p class="text-stone-600 max-w-2xl mx-auto italic">
        {t("reviews.desc")}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        reviews.map((review, index) => (
          <div
            class="bg-white p-8 rounded-2xl shadow-sm border border-stone-200 flex flex-col justify-between hover:shadow-xl transition-all duration-500 hover:-translate-y-2 group"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <div class="space-y-4">
              <div class="flex space-x-1" role="img" aria-label={lang === "en" ? `${review.stars} out of 5 stars` : lang === "fr" ? `${review.stars} étoiles sur 5` : `${review.stars} stelle su 5`}>
                {[...Array(review.stars)].map(() => (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5 text-amber-500 fill-current"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                  </svg>
                ))}
              </div>

              <p class="text-stone-700 leading-relaxed italic relative">
                <span class="absolute -top-4 -left-2 text-stone-200 text-6xl font-serif opacity-50 pointer-events-none group-hover:text-amber-200 transition-colors">
                  “
                </span>
                {review.text}
              </p>
            </div>

            <div class="mt-8 pt-6 border-t border-stone-100">
              <p class="font-serif text-lg text-stone-900">{review.name}</p>
              <div class="flex justify-between items-center mt-1">
                <span class="text-xs text-stone-400 uppercase tracking-tighter">
                  {review.date}
                </span>
                <span class="text-[10px] bg-stone-100 text-stone-500 px-2 py-0.5 rounded-full font-medium">
                  {review.source}
                </span>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16 text-center" data-aos="fade-up">
      <p class="text-stone-400 text-sm mb-4">
        {t("reviews.question")}
      </p>
      <a
        href="https://maps.app.goo.gl/9uwPwxciv7T9GPoR6"
        target="_blank"
        class="inline-flex items-center space-x-2 text-amber-600 font-semibold hover:text-amber-700 transition-colors underline decoration-amber-500/30 underline-offset-8 decoration-2 hover:decoration-amber-700"
      >
        <span>{t("reviews.cta")}</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* Subtle quote mark enhancement */
  @font-face {
    font-family: "SerifQuotes";
    src: local("Georgia");
  }
</style>
