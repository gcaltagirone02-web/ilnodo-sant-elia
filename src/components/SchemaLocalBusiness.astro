---
// src/components/SchemaLocalBusiness.astro
const lang = Astro.currentLocale || "it";

const schema = {
  "@context": "https://schema.org",
  "@type": "BarOrPub",
  name: "Il Nodo",
  url: "https://ilnodosantelia.it",
  telephone: "+393661770312",
  image: "https://ilnodosantelia.it/images/social-preview.png",
  priceRange: "€€",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Via dei Cantieri, snc",
    addressLocality: "Sant'Elia",
    addressRegion: "PA",
    postalCode: "90017",
    addressCountry: "IT",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 38.096131607001794,
    longitude: 13.539118486558483,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday",
      ],
      opens: "10:00",
      closes: "00:00",
    },
  ],
  menu: "https://ilnodosantelia.it/menu",
  servesCuisine:
    lang === "en"
      ? "Cocktails, Drinks, Aperitif"
      : "Cocktail, Aperitivi, Drink",
  sameAs: [
    "https://www.instagram.com/il_nodo_santelia/",
    "https://www.facebook.com/chioscoilnodo",
  ],
};
---

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(schema)}
/>
