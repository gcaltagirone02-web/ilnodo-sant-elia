---
import { SEO as AstroSEO } from "astro-seo";
import { useTranslations, defaultLang } from "../i18n/ui";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  type?: "website" | "article" | "restaurant";
}

const lang = (Astro.currentLocale as "it" | "en" | "fr") || defaultLang;
const t = useTranslations(lang);

// Map locales to OG locales
const ogLocaleMap = {
  it: "it_IT",
  en: "en_US",
  fr: "fr_FR",
};
const ogLocale = ogLocaleMap[lang as keyof typeof ogLocaleMap] || "it_IT";

const {
  title = t('seo.home.title'),
  description = t('seo.home.desc'),
  ogImage = "/images/social-preview.png",
  canonicalURL = Astro.url.href,
  type = "website",
} = Astro.props;

// JSON-LD LocalBusiness Data
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "Bar",
  name: "Il Nodo",
  description: t('seo.business.description'),
  url: "https://ilnodosantelia.it",
  telephone: "+393661770312",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Via dei Cantieri, snc",
    addressLocality: "Sant'Elia",
    addressRegion: "PA",
    postalCode: "90017",
    addressCountry: "IT",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: "38.1091",
    longitude: "13.5332",
  },
  priceRange: "€€",
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday",
      ],
      opens: "10:00",
      closes: "00:00",
    },
  ],
  sameAs: [
    "https://www.instagram.com/il_nodo_santelia/",
    "https://www.facebook.com/chioscoilnodo/",
  ],
};
---

<AstroSEO
  title={title}
  description={description}
  canonical={canonicalURL}
  openGraph={{
    basic: {
      title: title,
      type: type,
      image: ogImage,
    },
    optional: {
      siteName: "Il Nodo",
      locale: ogLocale,
    },
    image: {
      alt: t('seo.og_alt'),
      width: 1200,
      height: 630,
    },
  }}
  twitter={{
    card: "summary_large_image",
    site: "@il_nodo",
    title: title,
    description: description,
    image: ogImage,
    imageAlt: t('seo.og_alt'),
  }}
  extend={{
    link: [
      { rel: "icon", type: "image/png", href: "/favicon.png?v=4", sizes: "96x96" },
      { rel: "sitemap", href: "/sitemap-index.xml" },
    ],
    meta: [
      { name: "viewport", content: "width=device-width" },
      { name: "generator", content: Astro.generator },
      { name: "theme-color", content: "#0F1C46" },
      { name: "author", content: "Calta" },
      {
        name: "keywords",
        content: t('seo.keywords'),
      },
    ],
  }}
/>

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(localBusinessSchema)}
/>
