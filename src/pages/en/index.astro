---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Hero from "../../components/Hero.astro";
import Storytelling from "../../components/Storytelling.astro";
import ProductHighlights from "../../components/ProductHighlights.astro";
import SunsetExperience from "../../components/SunsetExperience.astro";
import Gallery from "../../components/Gallery.astro";
import Reviews from "../../components/Reviews.astro";
import Location from "../../components/Location.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations } from "../../i18n/ui";

const lang = "en";
const t = useTranslations(lang);
---

<Layout
  title={t("hero.title") + " " + t("hero.subtitle") + " — Il Nodo 2.0"}
  description="The perfect aperitif by the Sicilian sea. Discover Il Nodo 2.0 in Sant'Elia (Santa Flavia): craft cocktails, music, and breathtaking sunsets. Book your table!"
>
  <Navbar />
  <main>
    <Hero />
    <Storytelling id="storia" />
    <ProductHighlights id="prodotti" />
    <SunsetExperience id="sunset-experience" />
    <Gallery />
    <Reviews />
    <Location />
    <Footer />
  </main>
</Layout>
