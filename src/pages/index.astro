---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Storytelling from "../components/Storytelling.astro";
import ProductHighlights from "../components/ProductHighlights.astro";
import SunsetExperience from "../components/SunsetExperience.astro";
import Gallery from "../components/Gallery.astro";
import Reviews from "../components/Reviews.astro";
import Location from "../components/Location.astro";
import Footer from "../components/Footer.astro";
import { getSiteSettings } from "../lib/sanity/queries";

const currentPath = Astro.url.pathname;

// Verify Sanity connectivity (AC #3)
try {
  const settings = await getSiteSettings();
  if (settings) {
    console.log("Sanity Connection Success: Found site title:", settings.title);
  } else {
    console.warn("Sanity Connection: Site settings document not found.");
  }
} catch (error) {
  console.error("Sanity Connection Failed:", error);
}
---

<Layout
  title="Il Nodo 2.0 — Beach Bar a Sant'Elia | Aperitivo al Tramonto"
  description="Aperitivo al tramonto a Sant'Elia. Il Nodo 2.0: cocktail artigianali, musica e tramonti siciliani direttamente sul mare. Prenota il tuo tavolo via WhatsApp."
>
  <Navbar currentPath={currentPath} />
  <main>
    <Hero />
    <Storytelling id="storia" />
    <ProductHighlights id="prodotti" />
    <SunsetExperience id="sunset-experience" />
    <Gallery />
    <Reviews />
    <Location />
    <Footer />
  </main>
</Layout>
