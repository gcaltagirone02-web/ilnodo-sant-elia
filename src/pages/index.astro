---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Storytelling from "../components/Storytelling.astro";
import ProductHighlights from "../components/ProductHighlights.astro";
import SunsetExperience from "../components/SunsetExperience.astro";
import Gallery from "../components/Gallery.astro";
import Reviews from "../components/Reviews.astro";
import Location from "../components/Location.astro";
import Footer from "../components/Footer.astro";
import { getSiteSettings } from "../lib/sanity/queries";
import { useTranslations } from "../i18n/ui";

const lang = "it";
const t = useTranslations(lang);

// Verify Sanity connectivity (AC #3)
try {
  const settings = await getSiteSettings();
  if (settings) {
    console.log("Sanity Connection Success: Found site title:", settings.title);
  } else {
    console.warn("Sanity Connection: Site settings document not found.");
  }
} catch (error) {
  console.error("Sanity Connection Failed:", error);
}
---

<Layout
  title={t("hero.title") + " " + t("hero.subtitle") + " — Il Nodo 2.0"}
  description="L'aperitivo perfetto sul mare siciliano. Scopri Il Nodo 2.0 a Sant'Elia (Santa Flavia): cocktail artigianali, musica e tramonti mozzafiato. Prenota il tuo tavolo!"
>
  <Navbar />
  <main>
    <Hero />
    <Storytelling />
    <ProductHighlights />
    <SunsetExperience />
    <Gallery />
    <Reviews />
    <Location />
    <Footer />
  </main>
</Layout>
