import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import MenuGrid from "../../components/MenuGrid.astro";
import MenuCard from "../../components/MenuCard.astro";
import { Image } from "astro:assets";
import desktopHero from "../../assets/images/golden-hour-dektop-il-nodo.png";
import mobileHero from "../../assets/images/golden-hour-mobile-il-nodo.png";
import { getCategories, getMenuItems } from "../../lib/sanity/queries";
import { useTranslations } from "../../i18n/ui";

const lang = "fr";
const t = useTranslations(lang);

// GROQ Query for menu items
interface MenuItem {
  name: string;
  nameIt?: string;
  nameEn?: string;
  nameFr?: string;
  price: string;
  description?: string;
  descriptionEn?: string;
  descriptionFr?: string;
  ingredients?: string[];
  ingredientsEn?: string[];
  ingredientsFr?: string[];
  categorySlug: string;
  isHighlight?: boolean;
}

let items: MenuItem[] = [];
let sanityCategories: any[] = [];

try {
  [items, sanityCategories] = await Promise.all([
    getMenuItems(lang),
    getCategories(lang),
  ]);
} catch (error) {
  console.warn(
    "Sanity fetch failed, using fallback data. Check your projectId in astro.config.mjs.",
    error,
  );
}

// Category images
import cocktailsAlcoliciImg from "../../assets/images/cocktails.webp";
import cocktailsAnalcoliciImg from "../../assets/images/analcolici.webp";
import birreImg from "../../assets/images/birre.webp";
import viniImg from "../../assets/images/vini.webp";
import softDrinksImg from "../../assets/images/soft-drinks.webp";
import amariImg from "../../assets/images/amari.webp";
import stuzzichiniImg from "../../assets/images/stuzzichini-e-taglieri.webp";
import insalateImg from "../../assets/images/insalate.webp";
import paniniImg from "../../assets/images/panini.webp";

const localCategoryImages: Record<string, any> = {
  "cocktails-alcolici": cocktailsAlcoliciImg,
  "cocktails-analcolici": cocktailsAnalcoliciImg,
  birre: birreImg,
  vini: viniImg,
  "soft-drinks": softDrinksImg,
  amari: amariImg,
  stuzzichini: stuzzichiniImg,
  insalate: insalateImg,
  panini: paniniImg,
};

const categoryTitleMap: Record<string, string> = {
  "cocktails-alcolici": "menu.cat.cocktails",
  "cocktails-analcolici": "menu.cat.mocktails",
  birre: "menu.cat.beers",
  vini: "menu.cat.wines",
  "soft-drinks": "menu.cat.soft",
  amari: "menu.cat.spirits",
  stuzzichini: "menu.cat.appetizers",
  insalate: "menu.cat.salads",
  panini: "menu.cat.sandwiches",
};

// Categories with metadata for grid cards
const categories =
  sanityCategories.length > 0
    ? sanityCategories.map((cat) => {
        const translationKey = categoryTitleMap[cat.slug];
        return {
          name: translationKey ? t(translationKey as any) : cat.title,
          slug: cat.slug,
          image: cat.image || localCategoryImages[cat.slug] || cocktailsAlcoliciImg,
        };
      })
    : [
        {
          name: t("menu.cat.cocktails"),
          slug: "cocktails-alcolici",
          image: cocktailsAlcoliciImg,
        },
        {
          name: t("menu.cat.mocktails"),
          slug: "cocktails-analcolici",
          image: cocktailsAnalcoliciImg,
        },
        { name: t("menu.cat.beers"), slug: "birre", image: birreImg },
        { name: t("menu.cat.wines"), slug: "vini", image: viniImg },
        {
          name: t("menu.cat.soft"),
          slug: "soft-drinks",
          image: softDrinksImg,
        },
        { name: t("menu.cat.spirits"), slug: "amari", image: amariImg },
        { name: t("menu.cat.appetizers"), slug: "stuzzichini", image: stuzzichiniImg },
        { name: t("menu.cat.salads"), slug: "insalate", image: insalateImg },
        { name: t("menu.cat.sandwiches"), slug: "panini", image: paniniImg },
