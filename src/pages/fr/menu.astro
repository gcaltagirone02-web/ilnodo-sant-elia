// Group items by category
const groupedItems = items.reduce(
  (acc, item) => {
    const catSlug = item.categorySlug || "other";
    if (!acc[catSlug]) acc[catSlug] = [];
    acc[catSlug].push(item);
    return acc;
  },
  {} as Record<string, MenuItem[]>,
);

const displayData: Record<string, MenuItem[]> =
  items.length > 0 ? groupedItems : fallbackData;

// JSON-LD Menu Schema
const menuSchema = {
  "@context": "https://schema.org",
  "@type": "Menu",
  "name": t("menu.hero.title"),
  "description": t("menu.hero.subtitle"),
  "publisher": {
    "@type": "BarOrPub",
    "name": "Il Nodo 2.0",
    "url": "https://ilnodo.it"
  },
  "hasMenuSection": categories.map(cat => ({
    "@type": "MenuSection",
    "name": cat.name,
    "hasMenuItem": (displayData[cat.slug] || []).map(item => ({
      "@type": "MenuItem",
      "name": item.name,
      "description": item.description || (item.ingredients ? item.ingredients.join(", ") : ""),
      "offers": {
        "@type": "Offer",
        "price": item.price.replace(/[^\d.,]/g, "").replace(",", "."),
        "priceCurrency": "EUR"
      }
    }))
  }))
};
---

<Layout
  title="Menu | Il Nodo 2.0 — Bar de Plage à Sant'Elia"
  description="Découvrez notre menu en ligne : cocktails artisanaux, planches siciliennes et la fameuse granita au citron. Toute la saveur d'Il Nodo 2.0."
>
  <Navbar />

  <main class="menu-page">
    <section class="menu-hero">
      <div class="menu-hero__bg">
        <Image
          src={desktopHero}
          alt="Vue coucher de soleil Il Nodo"
          class="menu-hero__img menu-hero__img--desktop"
          loading="eager"
        />
        <Image
          src={mobileHero}
          alt="Vue coucher de soleil Il Nodo"
          class="menu-hero__img menu-hero__img--mobile"
          loading="eager"
        />
      </div>
      <div class="menu-hero__overlay"></div>
      <div class="menu-hero__content">
        <h1 class="menu-hero__title">{t("menu.hero.title")}</h1>
        <p class="menu-hero__subtitle">{t("menu.hero.subtitle")}</p>
        <div class="menu-hero__actions">
          <a href="#menu-categories" class="btn-browse">
            {t("menu.hero.cta")}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg
            >
          </a>
        </div>
      </div>
    </section>

    <div class="menu-container">
      <!-- Category Grid Navigation -->
      <nav class="category-grid" id="menu-categories">
        {
          categories.map((cat) => (
            <a
              href={`#${cat.slug}`}
              class="category-card"
              data-category={cat.slug}
            >
              <Image
                src={cat.image}
                alt={cat.name}
                class="category-card__image"
                width={64}
                height={64}
              />
              <span class="category-card__name">{cat.name}</span>
            </a>
          ))
        }
      </nav>

      <!-- Menu Sections -->
      {
        categories.map((cat) => (
          <section id={cat.slug} class="menu-section">
            <h2 class="menu-section__title">{cat.name}</h2>
            <MenuGrid>
              {displayData[cat.slug]?.map((item) => (
                <MenuCard
                  name={item.name}
                  price={item.price}
                  description={item.description}
                  ingredients={item.ingredients}
                  isHighlight={item.isHighlight}
                />
              ))}
            </MenuGrid>
          </section>
        ))
      }

      <footer class="menu-footer">
        <h2 class="menu-footer__title">{t("menu.footer.title")}</h2>
        <ul class="menu-footer__list">
          <li class="menu-footer__item">
            <span>{t("menu.footer.substitutions.label")}</span>
            {t("menu.footer.substitutions.text")}
          </li>
          <li class="menu-footer__item">
            <span>{t("menu.footer.custom.label")}</span>
            {t("menu.footer.custom.text")}
          </li>
          <li class="menu-footer__item">
            <span>{t("menu.footer.service.label")}</span>
            {t("menu.footer.service.text")}
          </li>
          <li class="menu-footer__item">
            <span>{t("menu.footer.hours.label")}</span>
            {t("menu.footer.hours.text")}
          </li>
        </ul>
      </footer>
    </div>

    <!-- Sticky Back to Categories Button -->
    <a
      href="#menu-categories"
      id="back-to-grid"
      class="sticky-back-btn"
      aria-label={t("menu.back")}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"><path d="m18 15-6-6-6 6"></path></svg
      >
      <span>{t("menu.back")}</span>
    </a>

  </main>

    <script type="application/ld+json" set:html={JSON.stringify(menuSchema)} is:inline />
    <Footer />
</Layout>

<style>
  .menu-page { background-color: var(--color-bg-primary); }
  .menu-hero {
    position: relative;
    height: 65vh;
    min-height: 550px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #0f1c46;
    overflow: hidden;
    margin-top: -5rem;
    padding-top: 8rem;
  }
  .menu-hero__overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 0%, rgba(15, 28, 70, 0.4) 100%), linear-gradient(to bottom, rgba(15, 28, 70, 0.3) 0%, rgba(15, 28, 70, 0.8) 100%);
    z-index: 1;
  }
  .menu-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .menu-hero__img { width: 100%; height: 100%; object-fit: cover; object-position: center; filter: brightness(0.7); }
  .menu-hero__img--mobile { display: none; }
  @media (max-width: 768px) { .menu-hero__img--desktop { display: none; } .menu-hero__img--mobile { display: block; } }
  .menu-hero__content { position: relative; z-index: 2; text-align: center; padding: 0 1.5rem; }
  .menu-hero__title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 10vw, 5rem);
    font-weight: 300;
    color: white;
    margin-bottom: 2rem;
    line-height: 1.1;
  }
  .menu-hero__subtitle {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.9);
    letter-spacing: 0.05em;
    line-height: 1.6;
    max-width: 45rem;
    margin: 0 auto;
  }
  .menu-hero__actions {
    margin-top: 4.5rem;
    animation: fadeInUp 0.8s ease-out 0.4s both;
  }
  .menu-container { max-width: 80rem; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
  .category-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 3rem; padding: 0 0.5rem; }
  .category-card { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 1.25rem 0.75rem; background-color: var(--color-bg-surface); border-radius: 1rem; border: 2px solid transparent; text-decoration: none; transition: border-color var(--duration-fast) var(--ease-smooth), transform var(--duration-fast) var(--ease-smooth), box-shadow var(--duration-fast) var(--ease-smooth); box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04); }
  .category-card:hover { border-color: var(--color-accent-amber); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08); }
  .category-card__image { width: 48px; height: 48px; object-fit: contain; margin-bottom: 0.5rem; }
  .category-card__name { font-family: var(--font-sans); font-size: 0.75rem; font-weight: 700; color: var(--color-text-primary); text-align: center; line-height: 1.2; }
  .menu-section { scroll-margin-top: 6rem; margin-bottom: 3rem; }
  .menu-section__title { font-family: var(--font-serif); font-size: 1.75rem; color: var(--color-text-primary); margin-bottom: 1.5rem; padding-bottom: 0.75rem; border-bottom: 2px solid var(--color-bg-elevated); }
  @media (min-width: 768px) { .category-grid { grid-template-columns: repeat(5, 1fr); gap: 1.25rem; } .category-card { padding: 1.5rem 1rem; } .category-card__image { width: 64px; height: 64px; } .category-card__name { font-size: 0.875rem; } }
  @media (min-width: 1024px) { .category-grid { grid-template-columns: repeat(9, 1fr); gap: 1.5rem; } }
  .menu-footer { margin-top: 4rem; padding: 2.5rem; background-color: var(--color-bg-elevated); border-radius: 1.5rem; }
  .menu-footer__title { font-family: var(--font-serif); font-size: 1.75rem; color: var(--color-text-primary); margin-bottom: 1.5rem; }
  .menu-footer__list { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
  .menu-footer__item { font-family: var(--font-sans); font-size: 0.9375rem; color: var(--color-text-secondary); display: flex; flex-direction: column; gap: 0.35rem; }
  .menu-footer__item span { color: var(--color-accent-amber); font-weight: 700; text-transform: uppercase; font-size: 0.75rem; }
  .btn-browse { display: inline-flex; align-items: center; gap: 0.75rem; padding: 1rem 2rem; background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 100px; color: white; font-family: var(--font-sans); font-weight: 600; text-decoration: none; }
  .sticky-back-btn { position: fixed; bottom: 2rem; right: 2rem; z-index: 50; display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; background: var(--color-accent-amber); border-radius: 100px; color: white; text-decoration: none; font-family: var(--font-sans); font-weight: 700; opacity: 0; visibility: hidden; transform: translateY(20px); transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .sticky-back-btn.is-visible { opacity: 1; visibility: visible; transform: translateY(0); }
  @media (max-width: 480px) { .category-grid { gap: 0.6rem; } .category-card { padding: 1.5rem 0.5rem; min-height: 160px; } .category-card__image { width: 68px; height: 68px; } .sticky-back-btn span { display: none; } }
</style>

<script>
  const backToGridBtn = document.getElementById("back-to-grid");
  const categoryGrid = document.getElementById("menu-categories");

  if (backToGridBtn && categoryGrid) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
            backToGridBtn.classList.add("is-visible");
          } else {
            backToGridBtn.classList.remove("is-visible");
          }
        });
      },
      { threshold: 0, rootMargin: "-100px 0px 0px 0px" },
    );
    observer.observe(categoryGrid);
  }
</script>
