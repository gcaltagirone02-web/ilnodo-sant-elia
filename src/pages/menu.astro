---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import MenuGrid from "../components/MenuGrid.astro";
import MenuCard from "../components/MenuCard.astro";
import { sanityClient } from "sanity:client";

// GROQ Query for menu items
interface MenuItem {
  name: string;
  price: string;
  description?: string;
  ingredients?: string[];
  category: string;
  isHighlight?: boolean;
}

let items: MenuItem[] = [];
try {
  items = await sanityClient.fetch<MenuItem[]>(`*[_type == "menuItem"] | order(orderRank asc, name asc) {
    name,
    price,
    description,
    ingredients,
    "category": category->title,
    isHighlight
  }`);
} catch (error) {
  console.warn("Sanity fetch failed, using fallback data. Check your projectId in astro.config.mjs.", error);
}

// Categories from inventory
const categories = ["Cocktails", "Beverages", "Food"];

// Fallback data from menu-inventory.md
const fallbackData: Record<string, MenuItem[]> = {
