    flex-direction: column;
    gap: 0.35rem;
    line-height: 1.6;
  }

  .menu-footer__item span {
    color: var(--color-accent-amber);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  #menu-categories {
    scroll-margin-top: 8rem; /* Increased to account for larger header context */
  }

  /* Hero Actions */
  .menu-hero__actions {
    margin-top: 4.5rem;
    animation: fadeInUp 0.8s ease-out 0.4s both;
  }

  .btn-browse {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 100px;
    color: white;
    font-family: var(--font-sans);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-smooth);
  }

  .btn-browse:hover {
    background: white;
    color: var(--color-text-primary);
    transform: translateY(-2px);
  }

  .btn-browse svg {
    transition: transform var(--duration-fast) var(--ease-smooth);
  }

  .btn-browse:hover svg {
    transform: translateY(3px);
  }

  /* Sticky Back Button */
  .sticky-back-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 50;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--color-accent-amber);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 100px;
    color: white;
    text-decoration: none;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.875rem;
    box-shadow:
      0 10px 25px -5px rgba(202, 138, 4, 0.4),
      0 8px 10px -6px rgba(202, 138, 4, 0.4);
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sticky-back-btn.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .sticky-back-btn:hover {
    background: #b47b04; /* Darker amber */
    transform: translateY(-3px) scale(1.05);
    box-shadow:
      0 20px 25px -5px rgba(202, 138, 4, 0.5),
      0 10px 10px -5px rgba(202, 138, 4, 0.5);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Mobile adjustments for category grid */
  @media (max-width: 480px) {
    .category-grid {
      gap: 0.6rem;
      padding: 0;
    }

    .category-card {
      padding: 1.5rem 0.5rem;
      min-height: 140px;
      justify-content: center;
    }

    .category-card__image {
      width: 64px;
      height: 64px;
      margin-bottom: 0.75rem;
    }

    .category-card__name {
      font-size: 0.825rem;
      padding: 0 0.2rem;
    }

    .sticky-back-btn {
      bottom: 1.5rem;
      right: 1.5rem;
      padding: 0.6rem 1rem;
    }

    .sticky-back-btn span {
      display: none;
    }
  }
</style>

<script>
  const backToGridBtn = document.getElementById("back-to-grid");
  const categoryGrid = document.getElementById("menu-categories");

  if (backToGridBtn && categoryGrid) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          // Se la griglia non è più visibile (scrolled past), mostra il pulsante
          if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
            backToGridBtn.classList.add("is-visible");
          } else {
            backToGridBtn.classList.remove("is-visible");
          }
        });
      },
      {
        threshold: 0,
        rootMargin: "-100px 0px 0px 0px",
      },
    );

    observer.observe(categoryGrid);
  }
</script>
