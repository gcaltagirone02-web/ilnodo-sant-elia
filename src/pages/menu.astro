  .menu-footer__title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    color: var(--color-text-primary);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .menu-footer__list {
    list-style: none;
    padding: 0;
