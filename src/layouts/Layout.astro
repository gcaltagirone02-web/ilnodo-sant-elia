---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import CookieConsentInit from "../components/CookieConsentInit.astro";
import SchemaLocalBusiness from "../components/SchemaLocalBusiness.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;

const lang = Astro.currentLocale || "it";
const site = "https://ilnodosantelia.it";

// Build hreflang alternate URLs for the current page
const pathname = Astro.url.pathname;
// Strip locale prefix to get the base path (e.g. "/en/menu/" → "/menu/", "/" → "/")
const basePath = pathname.replace(/^\/(en|fr)\//, "/").replace(/^\/(en|fr)$/, "/");
const alternates = [
  { hreflang: "it", href: `${site}${basePath}` },
  { hreflang: "en", href: `${site}/en${basePath === "/" ? "/" : basePath}` },
  { hreflang: "fr", href: `${site}/fr${basePath === "/" ? "/" : basePath}` },
  { hreflang: "x-default", href: `${site}${basePath}` },
];

// WebSite schema (global)
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Il Nodo",
  url: site,
  inLanguage: ["it", "en", "fr"],
};

// BreadcrumbList schema (dynamic per page)
const pageNameMap: Record<string, Record<string, string>> = {
  "/menu": { it: "Menu", en: "Menu", fr: "Menu" },
  "/menu/": { it: "Menu", en: "Menu", fr: "Menu" },
  "/privacy-policy": { it: "Privacy Policy", en: "Privacy Policy", fr: "Politique de Confidentialité" },
  "/privacy-policy/": { it: "Privacy Policy", en: "Privacy Policy", fr: "Politique de Confidentialité" },
  "/cookie-policy": { it: "Cookie Policy", en: "Cookie Policy", fr: "Politique des Cookies" },
  "/cookie-policy/": { it: "Cookie Policy", en: "Cookie Policy", fr: "Politique des Cookies" },
};

const isHome = basePath === "/" || basePath === "";
const pageName = pageNameMap[basePath]?.[lang as string] || null;

const breadcrumbSchema = !isHome && pageName ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Il Nodo",
      item: lang === "it" ? site : `${site}/${lang}`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: pageName,
    },
  ],
} : null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="96x96" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
    <link rel="manifest" href="/manifest.json" />
    <SEO title={title} description={description} ogImage={image} />
    <SchemaLocalBusiness />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(websiteSchema)} />
    {breadcrumbSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    )}

    {/* Hreflang: tell search engines about language variants */}
    {alternates.map(alt => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <!-- Preload critical fonts (Hero heading + CTA) to minimize CLS from font-display: swap -->
    <link rel="preload" href="/fonts/cormorant-garamond-v21-latin-300.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/plus-jakarta-sans-v12-latin-600.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <slot />
    <CookieConsentInit />
  </body>
</html>
