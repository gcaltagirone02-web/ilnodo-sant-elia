---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import CookieConsentInit from "../components/CookieConsentInit.astro";
import SchemaLocalBusiness from "../components/SchemaLocalBusiness.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;

const lang = Astro.currentLocale || "it";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <SEO title={title} description={description} ogImage={image} />
    <SchemaLocalBusiness />

    <!-- Fonts: self-hosted in global.css with font-display: swap -->
  </head>
  <body>
    <slot />
    <CookieConsentInit />
  </body>
</html>
